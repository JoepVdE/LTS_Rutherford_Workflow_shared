{
    "active_cable": "TEST_E_narrowkeyst_HEAVY",
    "wire_material": {
        "_comment": "Bilinear plasticity (MAT_PLASTIC_KINEMATIC) for copper wires in LS-DYNA. sigy_MPa: yield stress [MPa], etan_MPa: tangent modulus after yield [MPa].",
        "sigy_MPa": 20,
        "etan_MPa": 5000
    },
    "cablestack": {
        "_comment_formulation": "Element formulation for the cablestack solve: 1 = generalized plane strain + mixed u-P (default, magnet operating physics), 0 = plane stress (matches unconfined Zwick test BC). Patched into 0-start.inp at copy time.",
        "formulation": 1,
        "_comment_max_parallel": "Max MAPDL containers run concurrently for independent load stages (local Docker runs only; each container holds one license seat). 1 = fully sequential.",
        "max_parallel_stages": 4,
        "_comment_impreg": "Impregnation material: 1=epoxy RT, 2=wax RT, 3=epoxy LN2, 4=wax LN2",
        "impreg": 4,
        "_comment_bc": "Boundary condition type for displacement_transverse: 'cyclic' (multi-step strain ramp) or 'linear' (single step). Applies only to the displacement_transverse stage.",
        "bc_type": "cyclic",
        "_comment_boundary": "Boundary type for ALL 4 load stages: 'constrained' = sidewalls fixed perpendicular to load (cable inside a rigid die); 'free' = sidewalls drop their perpendicular constraints and the anchor moves to the loaded-against wall (Poisson-bulge allowed, matches an unconfined Zwick test). 'linear' + 'free' is not implemented.",
        "boundary_type": "constrained",
        "_comment_stages": "APDL cablestack simulations to run after templates are written. Each entry is a stage name in dependency order; dependencies are auto-included. The `build` stage (0-start.inp) writes base.db (mesh + contacts only, no SOLVE); the four load stages RESUME base.db and apply their own BCs from an UNDEFORMED state. Available: build (0-start.inp), displacement_transverse (00-restart-transverse.inp), displacement_radial (00-restart-radial.inp), pressure_transverse (00-restart-pressure.inp), pressure_radial (00-restart-pressure-radial.inp). Empty list = generate .inp files only, do not launch MAPDL. --no-cablestack overrides this to [].",
        "stages": [
            "displacement_transverse"
        ],
        "_comment_x_cab_margin": "Extra margin added to x_cab (half cable width) in mm",
        "x_cab_margin_mm": 0.5,
        "_comment_mesh_size": "Reference element size for impregnation and insulation free-mesh [um] at D_Strand = 0.85 mm. Applied size scales as value * (D_Strand / 0.85).",
        "mesh_size_um": 80,
        "_comment_strand_mesh_size": "Reference element size for strand areas free-mesh [um] at D_Strand = 0.85 mm. Applied size scales as value * (D_Strand / 0.85).",
        "strand_mesh_size_um": 80,
        "_comment_pressure": "Pressure loading (used by both pressure_transverse via 5-BC-pressure.inp and pressure_radial via 5-BC-radial.inp; also the -free siblings). Forces (peak_force_N, min_force_N) are converted to pressure via area = 2*x_cab * gauge_length_mm*1e-3. ramp_pressures_MPa: fixed intermediate peaks applied directly as SFL [MPa]. Cycle: ramp0, unload, ramp1, unload, ..., rampN, peak, unload.",
        "pressure": {
            "gauge_length_mm": 15.0,
            "peak_force_N": 45000,
            "min_force_N": 200,
            "ramp_pressures_MPa": [
                50.0,
                100.0,
                150.0
            ]
        }
    },
    "compression_box": {
        "_comment": "Compression box simulation (workflow step 9, opt-in): 3D parent MAG box solve -> .rmg->VTU -> field tables interpolated onto strand centers -> one-turn 2D submodel (one case per stack cross-section) -> strain/Ic analysis. Needs the step-7 conformal-mesh geometry. Force-run with --compbox, or standalone on the latest run with --compbox-only.",
        "enabled": false,
        "_comment_solver": "'local' = Docker MAPDL container (same compose service as cablestack), 'hpc' = SSH-reachable SLURM cluster (default ETH Euler; override via HPC_HOST/HPC_USER/HPC_REMOTE_BASE env vars; one job per solve; needs SSH key). The --hpc CLI flag forces 'hpc'.",
        "solver": "local",
        "_comment_measurement": "SINGLE SOURCE for the loading schedule AND the analysis reference: a BOX9.txt-style table (whitespace-separated columns: peak pressure [MPa], Ic under load [A], Ic after unload [A or NaN]; row 1 = baseline/virgin). At staging time compbox_stage.py generates the interleaved load/unload nsteps/totalCurr/pres_pusher block from it and writes it into BOTH the parent box deck (loading_schedule.inp) and 5-BC-submodel.inp (sentinel block), so they cannot drift. Bare names resolve against scripts/apdl/parentmodel/compbox/; absolute paths work too. Audit: <run>/APDL/compbox/loading_schedule.json.",
        "measurement_file": "BOX9.txt",
        "_comment_nsteps": "Optional cap on the number of loadsteps (0 = all pairs from the measurement table). Use an even value to keep load/unload pairs intact, e.g. 14 to stop after the 7th pressure level.",
        "nsteps": 0,
        "_comment_analysis": "Run complete_analysis.py + ic_calculator.py after the submodel solve.",
        "run_analysis": true,
        "_comment_impreg": "Impregnation material for the submodel (1=epoxy RT, 2=wax RT, 3=epoxy LN2, 4=wax LN2). Defaults to cablestack.impreg when omitted.",
        "_comment_local": "Docker solve resources: CPUs and memory per MPI rank [MB].",
        "local_ncpu": 4,
        "local_memory_mb": 4000,
        "_comment_hpc": "SLURM --ntasks for both the parent MAG and submodel jobs.",
        "hpc_ntasks": 24
    },
