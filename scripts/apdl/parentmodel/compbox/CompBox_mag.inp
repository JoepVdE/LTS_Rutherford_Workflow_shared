! Compression BOX magnetic model with ANSYS 3D
! Joep Van den Eijnden
! 02/012/2024
! Modified: Added time-dependent current analysis with multiple timesteps
! Each timestep uses a different current value from the totalCurr array
! /INPUT,CompBox,inp,C:/Users/vanden_j/OneDrive - ETH Zurich/Documents/ANSYS/APDL compressionBOX,0,0


FINISH  
/CLEAR,START
/RGB,INDEX,100,100,100, 0   
/RGB,INDEX, 80, 80, 80,13   
/RGB,INDEX, 60, 60, 60,14   
/RGB,INDEX, 0, 0, 0,15  


!Select cable
! <<<COMPBOX_PARENT_PARAMS_START>>> (values below are patched by compbox_stage.py)
cable_type = 'SMACC_HF_submodel'
wf_cable_width = 0
wf_cable_height = 0
! <<<COMPBOX_PARENT_PARAMS_END>>>
! wf_cable_* = 0 means: use the cable_type dimension branch below.
! Nonzero values (metres; 2*x_cab / 2*y_cab) override that branch, so any
! cable preset can run without a dedicated *elseif. Known cable_type tokens:
! CD1, CD1_submodel, Subscale, SMACC_LF, SMACC_HF, SMACC_HF_submodel.


/title,CompBox_MAG_%cable_type%
/filname,CompBox_MAG_%cable_type%,0

/UNITS,SI

/PREP7
/FACET,FINE  

/PNUM,KP,1
/PNUM,LINE,1
/PNUM,AREA,1
/PNUM,VOLU,0
/PNUM,NODE,0
/PNUM,TABN,0
/PNUM,SVAL,0
/PNUM,DOMA,0
/NUMBER,0   
!*  
/PNUM,ELEM,0
/REPLOT 

! Cable path
*set,straight_section_long_length,134.5e-3
*set,straight_section_short_length,38.e-3
*set,curve_radius,11.e-3

!meshsizing
LESIZE_cond = straight_section_long_length/100
LE135 = straight_section_long_length/100
DEG_246 = 5

! Physical definitions
tref,293 

! *set,mesh_size_cond,1e-3
! *set,mesh_size_air,mesh_size_cond/3

! interference and contact
*set,tol_contact,4.0e-5


! Initialize variables for cable dimensions
*set,cable_height,0
*set,cable_width,0
*set,insulation_thickness,0.15e-3 

! Assign dimensions based on the cable type
*if,cable_type,eq,'CD1',then
    *set,cable_height,1.5e-3+2*insulation_thickness
    *set,cable_width,10.1e-3+2*insulation_thickness
*elseif,cable_type,eq,'CD1_submodel',then
    *set,cable_height,2*0.93e-3
    *set,cable_width,2*5.1e-3
*elseif,cable_type,eq,'Subscale',then
    *set,cable_height,1.6e-3
    *set,cable_width,4.1e-3
*elseif,cable_type,eq,'SMACC_LF',then
    *set,cable_height,1.31e-3+2*insulation_thickness
    *set,cable_width,12.74e-3+2*insulation_thickness
*elseif,cable_type,eq,'SMACC_HF',then
    *set,cable_height,2.06e-3+2*insulation_thickness
    *set,cable_width,12.74e-3+2*insulation_thickness
*elseif,cable_type,eq,'SMACC_HF_submodel',then
    ! SMACC_HF deformed-cable submodel footprint. Matches the
    ! Rutherford-workflow convention: height = stack_height_mm = 2.36 mm
    ! (compressed height incl. insulation), width = 2*x_cab with the
    ! 0.5 mm/side impregnation margin: 2*(12.74/2 + 0.5) = 13.74 mm.
    *set,cable_height,2*1.18e-3
    *set,cable_width,2*6.87e-3
*else
    ! Unrecognized cable_type: dimensions must come from the workflow
    ! override block (wf_cable_width / wf_cable_height) patched at the top.
*endif

! Workflow override: nonzero wf_cable_* take precedence over the branch above.
*if,wf_cable_width,gt,0,then
    *set,cable_width,wf_cable_width
*endif
*if,wf_cable_height,gt,0,then
    *set,cable_height,wf_cable_height
*endif

! Guard: no dimensions resolved at all -> stop before building geometry.
*if,cable_width,le,0,then
    /eof
*endif



*set,air_domain_length,5.*straight_section_long_length
*set,air_domain_width,10.*straight_section_short_length

! Parameters
! *set,totalCurr,-20000




! BOX9 (SMACC_HF) measured loading schedule; box6_loading.inp is the CD1 one.
/inp,box9_loading,inp



! *set,mesh_size_cond,1.5e-3
! *set,mesh_size_air,5.e-2

!*set,mesh_size_air,mesh_size_cond*10
*set,mesh_size_cond,cable_height/5


! Initial current density - will be updated in solution loop
*set,J_total,totalCurr(1)/(cable_height*cable_width) ! current density; x, y, z refer to component


csys,0
z_offset = straight_section_long_length+curve_radius-cable_height/2
x_offset_14 = 0
y_offset_14 = +straight_section_short_length/2
z_offset_14 =  curve_radius-cable_height/2

local,14,1,x_offset_14,y_offset_14,z_offset_14,,,90. !used for radius Js of V2
local,15,1,x_offset_14,-y_offset_14,z_offset_14,,,90. !used for radius Js of V2


local,16,1,0,-curve_radius-straight_section_short_length/2+straight_section_short_length/2+curve_radius,cable_height+z_offset,,,90. !used for air domain
! local,17,0,straight_section_long_length/2.,-curve_radius-straight_section_short_length/2,cable_height,,,90 !used for air domain
! local,19,1,straight_section_long_length/2.,straight_section_short_length/2,cable_height,,,90 !used for air domain

! !!!!!!!!!!!!!!!!!!!!!!!!!
! GEOMETRY
!!!!!!!!!!!!!!!!!!!!!!!!!
csys,0 !Activates a previously defined coordinate system.


!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! UTwente Solenoid
! 	R inner	R outer	Z min	Z max	# Turns	Current
! 1	0.0418	0.056	-0.085	0.085	5210	24.0325
! 2	0.056	0.0591	-0.085	0.085	693	    24.0325
! 3	0.0635	0.0649	-0.11	0.11	554	    24.0325
! 4	0.0649	0.06725	-0.11	0.11	1359	24.0325
! 5	0.06725	0.0733	-0.11	0.11	4829	24.0325
! 6	0.0733	0.07905	0.013	0.11	2170	24.0325
! 7	0.07905	0.0872	0.013	0.11	4332	24.0325
! 8	0.0733	0.0788	-0.11	-0.013	2126	24.0325
! 9	0.0788	0.087	-0.11	-0.013	4335	24.0325

Ri_1 = 0.0418
Ro_1 =0.056
Zmin_1= -0.085
Zmax_1= 0.085

Ri_2=0.056
Ro_2=0.0591
Zmin_2= -0.085
Zmax_2= 0.085

Ri_3=0.0635
Ro_3=0.0649
Zmin_3=-0.11
Zmax_3=0.11

Ri_4=0.0649
Ro_4=0.06725
Zmin_4=-0.11
Zmax_4=0.11

Ri_5=   0.06725
Ro_5=   0.0733
Zmin_5= -0.11
Zmax_5= 0.11

Ri_6=   0.0733
Ro_6=   0.07905
Zmin_6= 0.013
Zmax_6= 0.11

Ri_7=   0.07905
Ro_7=   0.0872
Zmin_7= 0.013
Zmax_7= 0.11

Ri_8=   0.0733
Ro_8=   0.0788
Zmin_8= -0.11
Zmax_8= -0.013

Ri_9=	0.0788
Ro_9=   0.087
Zmin_9=-0.11
Zmax_9= -0.013

I_solenoid = 88 !voor 11 T
turns_1 = 5210
turns_2 = 693
turns_3 = 554
turns_4 = 1359
turns_5 = 4829
turns_6 = 2170
turns_7 = 4332
turns_8 = 2126
turns_9 = 4335


!!!!!!!!!!!!!!!!!!!!!!!!!
! COORDINATE SYS
!!!!!!!!!!!!!!!!!!!!!!!!!
local,100,1,0.,0.,0! lo
local,101,1,0.,0.,(Zmax_6+Zmin_6)/2! lo
local,102,1,0.,0.,(Zmax_8+Zmin_8)/2! lo

local,1111,0,10.,10.,10! lo

!Placed around origin 
CYLIND,Ri_1,Ro_1,Zmin_1,Zmax_1
vsel,s,,,1
CM, Magnet_1, volu

CYLIND,Ri_2,Ro_2,Zmin_2,Zmax_2
vsel,s,,,2
CM, Magnet_2, volu


!Coil 3
CYLIND,Ri_3,Ro_3,Zmin_6,Zmax_6
vsel,s,,,3
CM, Magnet_3a, volu

CYLIND,Ri_3,Ro_3,Zmax_8,Zmin_6
vsel,s,,,4
CM, Magnet_3b, volu

CYLIND,Ri_3,Ro_3,Zmin_8,Zmax_8
vsel,s,,,5
CM, Magnet_3c, volu

!Coil 4
CYLIND,Ri_4,Ro_4,Zmin_6,Zmax_6
vsel,s,,,6
CM, Magnet_4a, volu

CYLIND,Ri_4,Ro_4,Zmax_8,Zmin_6
vsel,s,,,7
CM, Magnet_4b, volu

CYLIND,Ri_4,Ro_4,Zmin_8,Zmax_8
vsel,s,,,8
CM, Magnet_4c, volu

!Coil 5
CYLIND,Ri_5,Ro_5,Zmin_6,Zmax_6
vsel,s,,,9
