! vsel,s,,,7
! CM, Magnet_7, volu

! CYLIND,Ri_9,Ro_9,Zmin_9,min_9
! vsel,s,,,9
! CM, Magnet_9, volu


z_offset = straight_section_long_length+curve_radius-cable_height/2

LOCAL,103,0,-cable_width/2.,straight_section_short_length/2+curve_radius,z_offset,,,90
LOCAL,104,0,-cable_width/2.,straight_section_short_length/2+curve_radius,z_offset,,
LOCAL,105,,x_offset,y_offset,z_offset,0,0,0,0,0


csys,103 !Activates a previously defined coordinate system.
k,1000,0.0,0.0 !creates keypoint with ID1000 at coordinates 0,0 in XY plane.  K, NPT, X, Y, Z
k,1003,straight_section_long_length,0.0,0.0 !end of straight line
k,1004,straight_section_long_length+curve_radius,-curve_radius, 0. !curve 
!k,1002,straight_section_long_length+curve_radius/2.01,curve_radius/2.,0. !curve help point to give outside of radius
k,1002,0.-1e-3,0. !curve help point to give outside of radius
k,1005,straight_section_long_length+curve_radius,-curve_radius-straight_section_short_length, 0. !curve 
k,1006,straight_section_long_length,-2.*curve_radius-straight_section_short_length, 0. !curve 
k,1007,0.,-2.*curve_radius-straight_section_short_length,0.
k,1008,straight_section_long_length+curve_radius,-curve_radius-straight_section_short_length/2, 0. !curve 

!keypoints for conductor area
csys,103
k,1011,0.,0.,cable_width
k,1012,0.,cable_height,cable_width
k,1013,0.,cable_height,0.
a,1000,1011,1012,1013

asel,s,loc,x,0
cm,conductor_area,area


csys,103
!create lines for path compression box
l,1000,1003 							! line 1000, straight section
larc,1003,1004,1002,curve_radius			! line 1002, hard-way bend LARC, P1, P2, PC, RAD 

csys,103
l,1004,1005
larc,1005,1006,1002,curve_radius
l,1006,1007
csys,103
k,1014,-0.1,-curve_radius-straight_section_short_length/2
larc,1007,1000,1014,straight_section_short_length/2.+curve_radius



! Half symmetry (not used)
!l,1000,1003 							! line 1000, straight section
!larc,1003,1004,1002,curve_radius			! line 1002, hard-way bend LARC, P1, P2, PC, RAD 
!l,1004,1008



csys,0
vdrag,conductor_area,,,,,,33,34,35,36,39,40!,1003,1004,1005,1006
NUMMRG,all  !get rid of double defined items

vsel,s,,,18
CM,Cable_1,volu
allsel,below,volume
CM,Cable_1_lines,line
VPLOT

vsel,s,,,19
CM,Cable_2,volu
allsel,below,volume
CM,Cable_2_lines,line

vsel,s,,,20
