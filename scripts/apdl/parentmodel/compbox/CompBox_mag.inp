CMSEL,a,Cable_5_lines
CMSEL,a,Cable_6_lines
lplot


!airbox
CYLIND,,7*Ro_9,7*Zmin_9,7*Zmax_7

allsel
!VSBV,7,all,,delete,keep
!box_size=0.3
!BLOCK, box_size, -box_size, box_size, -box_size,box_size, -box_size
VSBV,24,all,,delete,keep

NUMMRG,all  !get rid of double defined items
et,1,solid236       !Air 3D structural element in ANSYS: 
keyopt,1,1,0
keyopt,1,8,1         ! use Maxwell force option
et,11,solid236      !Conductor 3D structural element in ANSYS: 
keyopt,1,1,0
keyopt,11,8,1        ! use Maxwell force option

mur=1
mp,murx,1,mur       !Air 
mp,murx,11,mur      !Coil  



csys,0
csys,0

num_subdivisions =15
