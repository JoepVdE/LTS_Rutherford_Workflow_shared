!Coil 7
CYLIND,Ri_7,Ro_7,Zmin_6,Zmax_6
vsel,s,,,15
CM, Magnet_7, volu

!Air 7-8
CYLIND,Ri_7,Ro_7,Zmax_8,Zmin_6
vsel,s,,,16
CM, air7_9, volu

!Coil 9
CYLIND,Ri_7,Ro_7,Zmin_8,Zmax_8
vsel,s,,,17
CM, Magnet_9, volu
NUMMRG,all  !get rid of double defined items


! CYLIND,Ri_7,Ro_7,Zmin_8,Zmax_6
! vsel,s,,,7
! CM, Magnet_7, volu

! !Placed around z=-0.123/2
