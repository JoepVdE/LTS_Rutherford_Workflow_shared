CYLIND,Ri_5,Ro_5,Zmin_8,Zmax_8
vsel,s,,,11
CM, Magnet_5c, volu


!Coil 6
CYLIND,Ri_6,Ro_6,Zmin_6,Zmax_6
vsel,s,,,12
CM, Magnet_6, volu

!Air 6-8
CYLIND,Ri_6,Ro_6,Zmax_8,Zmin_6
vsel,s,,,13
