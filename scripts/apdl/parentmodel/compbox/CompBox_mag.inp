allsel,below,volu
VATT,11,,11,, !Set element to conductor
VPLOT
LSEL,r,loc,z,Zmax_3
LESIZE,all,,,num_subdivisions

allsel
cmsel,s,Magnet_6
allsel,belo,volu
LSEL,r,loc,z,Zmin_6+0.01,Zmax_6-0.01
LESIZE,all,,,num_subdivisions_axiala


ASEL,s,,,68
AESIZE,68,(Ro_6-Ri_6)/2
allsel
vsweep,12,68,67      ! Mesh volume 1

!5b Zmax_8,Zmin_6
allsel
cmsel,s,air6_8
allsel,below,volu
VATT,11,,11,, !Set element to conductor
LSEL,r,loc,z,Zmin_6-0.01,Zmax_8+0.01
LESIZE,all,,,num_subdivisions_axialb

allsel
cmsel,s,air6_8
allsel,belo,volu
vsweep,13,67,73      ! Mesh volume 1


!5c Zmax_8,Zmin_8
allsel
cmsel,s,Magnet_8
allsel,below,volu
VATT,11,,11,, !Set element to conductor
LSEL,r,loc,z,Zmin_8+0.01,Zmax_8-0.01
LESIZE,all,,,num_subdivisions_axialc

allsel
cmsel,s,Magnet_8
allsel,belo,volu
vsweep,14,73,79      ! Mesh volume 1

allsel
EPLOT


!MESH_7
allsel
cmsel,s,Magnet_7
allsel,below,volu
VATT,11,,11,, !Set element to conductor
VPLOT
LSEL,r,loc,z,Zmax_3
LESIZE,all,,,num_subdivisions

allsel
cmsel,s,Magnet_7
allsel,belo,volu

LSEL,r,loc,z,Zmin_6+0.01,Zmax_6-0.01
LESIZE,all,,,num_subdivisions_axiala


ASEL,s,,,86
AESIZE,86,(Ro_6-Ri_6)/2
allsel
vsweep,15,86,85      ! Mesh volume 1

!5b Zmax_8,Zmin_6
allsel
cmsel,s,air7_9
allsel,below,volu
VATT,11,,11,, !Set element to conductor
LSEL,r,loc,z,Zmin_6-0.01,Zmax_8+0.01
LESIZE,all,,,num_subdivisions_axialb

allsel
cmsel,s,air7_9
allsel,belo,volu
vsweep,16,85,91      ! Mesh volume 1


!5c Zmax_8,Zmin_8
allsel
cmsel,s,Magnet_9
allsel,below,volu
VATT,11,,11,, !Set element to conductor
LSEL,r,loc,z,Zmin_8+0.01,Zmax_8-0.01
LESIZE,all,,,num_subdivisions_axialc

allsel
cmsel,s,Magnet_9
allsel,belo,volu
vsweep,17,91,97      ! Mesh volume 1

allsel

!!MESH_AIR
csys,0
esys,0
VSEL,s,VOLU,,25  !
VATT,1,,1,, !to air
VPLOT
mshape,1,3D
MSHKEY,0       ! Explicitly request free meshing (MSHKEY,0 for strictly free meshing)

allsel


asel,s,,,92,95
aesize,all,1e-1

! mopt,vmesh,ALTERNATE
mopt,pyra,on    ! Set smart size for meshing
mopt,TRANS,4

MOPT,STAT

VMESH,ALL  


csys,100
esys,100


!Set current
allsel
cmsel,s,Magnet_1
allsel,below,volume
J_1 = turns_1*I_solenoid/((Ro_1-Ri_1)*(Zmax_1-Zmin_1))
BFE, ALL, Js,,,J_1

!Set current
allsel
cmsel,s,Magnet_2
allsel,below,volume
J_2 = turns_2*I_solenoid/((Ro_2-Ri_2)*(Zmax_2-Zmin_2))
BFE, ALL, Js,,,J_2

!Set current
allsel
cmsel,s,Magnet_3a
cmsel,a,Magnet_3b
cmsel,a,Magnet_3c

allsel,below,volume
J_3 = turns_3*I_solenoid/((Ro_3-Ri_3)*(Zmax_3-Zmin_3))
BFE, ALL, Js,,,J_3

!Set current
allsel
cmsel,s,Magnet_4a
cmsel,a,Magnet_4b
cmsel,a,Magnet_4c
allsel,below,volume
J_4 = turns_4*I_solenoid/((Ro_4-Ri_4)*(Zmax_4-Zmin_4))
BFE, ALL, Js,,,J_4

!Set current
allsel
cmsel,s,Magnet_5a
cmsel,a,Magnet_5b
cmsel,a,Magnet_5c
allsel,below,volume
J_5 = turns_5*I_solenoid/((Ro_5-Ri_5)*(Zmax_5-Zmin_5))
BFE, ALL, Js,,,J_5

!Set current magnet 6
allsel
cmsel,s,Magnet_6
allsel,below,volume
!eSEL,r,cent,z,Zmin_6,Zmax_6,,
J_6 = turns_6*I_solenoid/((Ro_6-Ri_6)*(Zmax_6-Zmin_6))
BFE, ALL, Js,,,J_6

!Set current magnet 7
allsel
cmsel,s,Magnet_7
allsel,below,volume
!eSEL,r,cent,z,Zmin_7,Zmax_7,,
J_7 = turns_7*I_solenoid/((Ro_7-Ri_7)*(Zmax_7-Zmin_7))
BFE, ALL, Js,,,J_7

!Set current magnet 8
allsel
cmsel,s,Magnet_8
allsel,below,volume
!eSEL,r,cent,z,Zmin_8,Zmax_8,,
J_8 = turns_8*I_solenoid/((Ro_8-Ri_8)*(Zmax_8-Zmin_8))
BFE, ALL, Js,,,J_8

!Set current magnet 9
allsel
cmsel,s,Magnet_9
allsel,below,volume
!eSEL,r,cent,z,Zmin_9,Zmax_9,,
J_9 = turns_9*I_solenoid/((Ro_9-Ri_9)*(Zmax_9-Zmin_9))
BFE, ALL, Js,,,J_9



! Current densities for conductor will be applied in solution loop

allsel
CMGRP,Conductor,Cable_1,Cable_2,Cable_3,Cable_4,Cable_5


allsel


csys,0
/SOLU

ANTYPE,STATIC

!EQSLV,SPARSE!

! Az boundary conditions
da,92,az,0
da,95,az,0
da,96,az,0
da,98,az,0

! Loop through different timesteps with different currents
*do,istep,1,nsteps,1
    
    ! Update current density for this timestep
    *set,J_total,totalCurr(istep)/(cable_height*cable_width)
    
    ! Clear previous current densities
    ! LSCLEAR,JS
    
    ! Apply current densities to conductor components
    csys,0
    esys,0
    cmsel,s,Cable_1
    allsel,below,volume
    BFE, ALL, Js,,,,-J_total

    cmsel,s,Cable_3
    allsel,below,volume
    BFE, ALL, Js,,,-J_total

    cmsel,s,Cable_5
    allsel,below,volume
    BFE, ALL, Js,,,,J_total

    csys,14
    esys,14
    cmsel,s,Cable_2
    allsel,below,volume
    BFE, ALL, Js,,,-J_total

    csys,15
    esys,15
    cmsel,s,Cable_4
    allsel,below,volume
    BFE, ALL, Js,,,-J_total

    csys,16
    esys,16
    cmsel,s,Cable_6
    allsel,below,volume
    BFE, ALL, Js,,,-J_total

    allsel
    
    ! Set time for this load step
    time,istep
    
    ! Solve for this timestep
    solve
    
*enddo

finish

/post1

! Post-process results for all timesteps
*do,istep,1,nsteps,1
    
    ! Read results for this timestep
    set,istep
    
    ! Output current information
    *msg,info
    Processing timestep %G with current = %G A
    istep,totalCurr(istep)
    
    ! Define path for magnetic field along centerline
    !PATH,NAME,nPts,nSets,nDiv
    PATH,Center_line,2,20,50
    !PPATH,POINT,NODE,X,Y,Z,CS
    PPATH, 1,, 0, 0, -Zmax_1*3, 0
    PPATH, 2,, 0, 0, Zmax_1*3, 0
    !PDEF,Lab,Item,Comp,Avglab
    PDEF,Bx,B,x,avg
    PDEF,By,B,y,avg
    PDEF,Bz,B,z,avg
    
    ! Plot for this timestep
    PLPATH,Bx,By,Bz
    
    ! Optional: Save images for each timestep
    /show,png
    /view,1,1,1,1
    /IMAGE,save,Balongaxis_compBOX_step%istep%,png
    
*enddo

! Set to last timestep for final display
set,nsteps

/REPLOT 
! /show,png                ! Set the output format to PNG (or another format like JPG or BMP)
! /view,1,1,1,1             ! Ensure the correct view is set (optional, to define the view you want)
! /IMAGE,save,Balongaxis_compBOX,png



