!GENERATE SIDE SUPPORT mesh
*IF,side_support,EQ,1,THEN

    n_conta_sidewall = n_contact_element


    et,n_contact_element,CONTA172
    KEYOPT,n_contact_element,1,0
    KEYOPT,n_contact_element,9,3
    KEYOPT,n_contact_element,12,0
    mp,mu,n_contact_element,0.2
    r,n_contact_element
