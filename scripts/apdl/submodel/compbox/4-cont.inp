    cmsel,a,right_side_support
    allsel,belo,area


    type,1000+n_contact_element
    esurf
    allsel


*ENDIF




r_start = 1
r_max = n_contact_element


*do,i,r_start,r_max,1
    rmod,i,6,0.1 !Set 0.1 for the pinball region 
