
allsel
eplot
n_contact_element = 1000 !starting number for contact elements


! Contacts elements between strands
*DO,stack_nr,1,n_stacks
    /input,contacts_strands_%stack_nr%,txt
*ENDDO






! n_contact_element = 1e4*n_strands !starting number for contact elements


*DO,i_sta,1,n_stacks
    /input,inner_insulation_lines_%i_sta%,txt
    /input,outer_insulation_lines_%i_sta%,txt
*ENDDO


n_contact_element = 1e6

! i_sta = 1
! i_str = 1
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!!!! Strand - impregnation
!!!!! Strand - insulation
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!


allsel
eplot
*DO,i_sta,1,n_stacks
    *DO,i_str,1,n_strands
        min_x_coor = 0
        min_y_coor = 0
        max_x_coor = 0
        max_y_coor = 0


        et,n_contact_element,CONTA172
        KEYOPT,n_contact_element,1,0
        KEYOPT,n_contact_element,9,1
        KEYOPT,n_contact_element,12,2
        mp,mu,n_contact_element,0.2
        r,n_contact_element

        et,n_contact_element+5000,TARGE169
        real,n_contact_element
        mat,n_contact_element


        allsel
        cmsel,none
        asel,none

        cmsel,a,i_%i_sta%_%i_str%
        cmsel,a,m_%i_sta%_%i_str%
        cmsel,a,o_%i_sta%_%i_str%

        allsel,belo,area


        margin = 0.05e-3 !0.1 mm margin for contact elements
        *GET, min_x_coor, NODE, 0, MNLOC, X 
        min_x_coor = min_x_coor - margin
        *GET, min_y_coor, NODE, 0, MNLOC, Y
        min_y_coor = min_y_coor - margin
        *GET, max_x_coor, NODE, 0, MXLOC, X
        max_x_coor = max_x_coor + margin
        *GET, max_y_coor, NODE, 0, MXLOC, Y 
        max_y_coor = max_y_coor + margin


        type,n_contact_element
        ! eplot 

        esurf 






        allsel
        cmsel,none
        asel,none

        cmsel,a,out_imp_%i_sta%
        ! cmsel,a,STR_IMP_%i_sta% !insulation       


        allsel,belo,area

        lsel,r,loc,x,min_x_coor,max_x_coor
        lsel,r,loc,y,min_y_coor,max_y_coor
        
        NSLL,s,1
        ESLN,s,0,all

        type,5000+n_contact_element
        esurf
        allsel



        n_contact_element=n_contact_element+1


        et,n_contact_element,CONTA172
        KEYOPT,n_contact_element,1,0
        KEYOPT,n_contact_element,9,1
        KEYOPT,n_contact_element,12,2
        mp,mu,n_contact_element,0.2
        r,n_contact_element

        et,n_contact_element+5000,TARGE169
        real,n_contact_element
        mat,n_contact_element


        allsel
        cmsel,none
        asel,none

        cmsel,a,i_%i_sta%_%i_str%
        cmsel,a,m_%i_sta%_%i_str%
        cmsel,a,o_%i_sta%_%i_str%

        allsel,belo,area

        type,n_contact_element
        ! eplot 
        esurf 


        allsel
        cmsel,none
        asel,none

        ! cmsel,a,out_imp_%i_sta%
        !cmsel,a,STR_IMP_%i_sta% !insulation
        cmsel,s,inner_insulation_%i_sta%

        LSLK,s,0

        ! allsel,belo,area

        lsel,r,loc,x,min_x_coor,max_x_coor
        lsel,r,loc,y,min_y_coor,max_y_coor


        
        NSLL,s,1
        ESLN,s,0,all

        type,5000+n_contact_element
        esurf
        allsel

        n_contact_element=n_contact_element+9

    *ENDDO

    n_contact_element = 1e6 + i_sta*10000 !reset contact element number for next stack
*ENDDO




allsel
eplot

n_contact_element = 2e6

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!impregnation to insulation

!!!!!!!!!!!!!!!!!!!!!!!

allsel
*DO,i_sta,1,n_stacks
    n_offset = offset_impreg_%i_sta%
    *DO,i_impreg,1,n_strands*3
        et,n_contact_element,CONTA172
        KEYOPT,n_contact_element,1,0
        KEYOPT,n_contact_element,9,1
        KEYOPT,n_contact_element,12,3
        mp,mu,n_contact_element,0.2
        r,n_contact_element

        et,n_contact_element+5000,TARGE169
        real,n_contact_element
        mat,n_contact_element


        allsel
        asel,none
        asel,s,,,n_offset-1+i_impreg

        allsel,belo,area


        margin = 0.05e-3 !0.1 mm margin for contact elements
        *GET, min_x_coor, NODE, 0, MNLOC, X 
        min_x_coor = min_x_coor - margin
        *GET, min_y_coor, NODE, 0, MNLOC, Y
        min_y_coor = min_y_coor - margin
        *GET, max_x_coor, NODE, 0, MXLOC, X
        max_x_coor = max_x_coor + margin
        *GET, max_y_coor, NODE, 0, MXLOC, Y 
        max_y_coor = max_y_coor + margin


        type,n_contact_element
        ! eplot 

        esurf 


        allsel
        cmsel,none
        asel,none
        lsel,none
        ksel,none
        cmsel,s,inner_insulation_%i_sta%
        ! cmsel,a,STR_IMP_%i_sta% !insulation       

        LSLK,s,0

        lsel,r,loc,x,min_x_coor,max_x_coor
        lsel,r,loc,y,min_y_coor,max_y_coor
        
        NSLL,s,1
        ESLN,s,0,all

        type,5000+n_contact_element
        esurf
        allsel
        n_contact_element=n_contact_element+1


    *ENDDO
    n_contact_element = 2e6 + (i_sta)*10000 !reset contact element number for next stack

*ENDDO

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!bond insulations together
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
n_contact_element = 3e6


allsel

*DO,i_sta,2,n_stacks
    et,n_contact_element,CONTA172
    KEYOPT,n_contact_element,1,0
    KEYOPT,n_contact_element,9,1
    KEYOPT,n_contact_element,12,3 ! (bonded)
    mp,mu,n_contact_element,0.2
    r,n_contact_element

    et,n_contact_element+5000,TARGE169
    real,n_contact_element
    mat,n_contact_element

    allsel
    cmsel,none
    asel,none
    lsel,none
    ksel,none

    cmsel,a,outer_insulation_%i_sta% !insulation
    LSLK,s,0
    NSLL,s,1
    ESLN,s,0,all


    type,n_contact_element
    ! eplot

    esurf

    allsel
    allsel
    cmsel,none
    asel,none
    lsel,none
    ksel,none

    cmsel,s,outer_insulation_%i_sta-1% !insulation
    LSLK,s,0
    NSLL,s,1
    ESLN,s,0,all

    type,5000+n_contact_element
    esurf
    n_contact_element=n_contact_element+1

*ENDDO

allsel


n_contact_element = 4e6

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!!!!!!!!!!!!!!!bond insulation to impregnation outside
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
et,n_contact_element,CONTA172
KEYOPT,n_contact_element,1,0
KEYOPT,n_contact_element,9,1
KEYOPT,n_contact_element,12,3 ! (bonded)
mp,mu,n_contact_element,0.2
r,n_contact_element

et,n_contact_element+5000,TARGE169
real,n_contact_element
mat,n_contact_element

allsel

cmsel,none
asel,none
lsel,none
ksel,none
*DO,i_sta,1,n_stacks
    ! cmsel,a,STR_IMP_%i_sta% !insulation
    cmsel,a,outer_insulation_%i_sta% !insulation

*ENDDO
LSLK,s,0
NSLL,s,1
ESLN,s,0,all
! allsel,belo,area
type,n_contact_element
! eplot
esurf

allsel
cmsel,none
asel,none
cmsel,s,str_outer_imp

allsel,belo,area
type,5000+n_contact_element
esurf
n_contact_element=n_contact_element+1







!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!!!!compression box sides!!!!!!!!!!!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
n_contact_element = 5e6



!pusher to steel box
et,n_contact_element,CONTA172
KEYOPT,n_contact_element,1,0
KEYOPT,n_contact_element,9,1
KEYOPT,n_contact_element,12,0 ! (bonded)
mp,mu,n_contact_element,0.2
r,n_contact_element

et,n_contact_element+5000,TARGE169
real,n_contact_element
mat,n_contact_element

cmsel,none
asel,none
lsel,none
ksel,none

cmsel,s,box_steel


LSLA,s,0
lsel,r,loc,x,-x_cab-0.0001,x_cab+0.0001
lsel,r,loc,y,-y_cab-0.0001,y_cab+thickness_steel+0.0001
lplot
NSLL,s,1
ESLN,s,0,all
! allsel,belo,area
type,n_contact_element
! eplot
esurf

allsel
cmsel,none
asel,none
cmsel,s,pusher

allsel,belo,area
type,5000+n_contact_element
esurf
n_contact_element=n_contact_element+1



!conductor to steel box
et,n_contact_element,CONTA172
KEYOPT,n_contact_element,1,0
KEYOPT,n_contact_element,9,1
KEYOPT,n_contact_element,12,0 ! (standard)
mp,mu,n_contact_element,0.2
r,n_contact_element

et,n_contact_element+5000,TARGE169
real,n_contact_element
mat,n_contact_element

cmsel,none
asel,none
lsel,none
ksel,none


cmsel,s,box_steel
! cmsel,a,pusher


LSLA,s,0
lsel,r,loc,x,-x_cab-0.0001,x_cab+0.0001
lsel,r,loc,y,-y_cab-0.0001,y_cab+thickness_steel+0.0001
cm,lines_box,lines
lplot

cmsel,s,pusher
LSLA,s,0
lsel,r,loc,y,-y_cab-thickness_steel,y_cab+0.0001
lplot

cmsel,a,lines_box

NSLL,s,1
ESLN,s,0,all

type,n_contact_element
! eplot
esurf


!select outer lines impregnation
margin_line = 1e-6

cmsel,s,str_outer_imp
LSLA,s,0
lsel,r,loc,x,x_cab-margin_line,x_cab+margin_line
lplot
cm,outer_imp_lines,lines

cmsel,s,str_outer_imp
LSLA,s,0
lsel,r,loc,x,-x_cab-margin_line,-x_cab+margin_line
cmsel,a,outer_imp_lines
cm,outer_imp_lines,lines

cmsel,s,str_outer_imp
LSLA,s,0
lsel,r,loc,y,-y_cab-margin_line,-y_cab+margin_line
cmsel,a,outer_imp_lines
cm,outer_imp_lines,lines

cmsel,s,str_outer_imp
LSLA,s,0
lsel,r,loc,y,y_cab-margin_line,y_cab+margin_line
cmsel,a,outer_imp_lines
cm,outer_imp_lines,lines

cmsel,s,outer_imp_lines
lplot
NSLL,s,1
ESLN,s,0,all
allsel,belo,area


type,5000+n_contact_element
esurf

n_contact_element=n_contact_element+1

!conductor to steel box
et,n_contact_element,CONTA172
KEYOPT,n_contact_element,1,0
KEYOPT,n_contact_element,9,1
KEYOPT,n_contact_element,12,0 ! (bonded)
mp,mu,n_contact_element,0.2
r,n_contact_element

et,n_contact_element+5000,TARGE169
real,n_contact_element
mat,n_contact_element

cmsel,none
asel,none
lsel,none
ksel,none


cmsel,s,box_steel
! cmsel,a,pusher


LSLA,s,0
lsel,r,loc,x,-x_cab-0.0001,x_cab+0.0001
lsel,r,loc,y,-y_cab-0.0001,y_cab+thickness_steel+0.0001
cm,lines_box,lines
lplot

cmsel,s,pusher
LSLA,s,0
lsel,r,loc,y,-y_cab-thickness_steel,y_cab+0.0001
lplot

cmsel,a,lines_box

NSLL,s,1
ESLN,s,0,all

type,n_contact_element
! eplot
esurf

! cmsel,s,str_outer_imp
! LSLA,s,0


!select outshirts of conductor
! 
cmsel,none
asel,none
lsel,none
ksel,none
*DO,i_sta,1,n_stacks
    ! cmsel,a,STR_IMP_%i_sta% !insulation
    cmsel,a,outer_insulation_%i_sta% !insulation

*ENDDO
LSLK,s,0
NSLL,s,1
ESLN,s,0,all

type,5000+n_contact_element
esurf



/eof




























































































