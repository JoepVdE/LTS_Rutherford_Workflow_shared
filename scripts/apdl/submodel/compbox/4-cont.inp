! !!Pinball region

! ! --- Step 1: Select all contact element types (e.g., CONTA172) ---
! allsel
! ETSEL, NONE
! *DO, etid, 1, 10000
!     *GET, etname, ETYP, etid, ATTR, LIBRARY
!     *IF, etname, EQ, 'CONTA172', THEN
!         ETSEL, ADD, etid
!     *ENDIF
! *ENDDO

! ESEL, NONE
! ESEL, R, TYPE    ! Select all elements of selected types (CONTA172)

! *GET, nelem, ELEM, 0, COUNT
! *DIM, elist, ARRAY, nelem
! VGET, elist(1), ELEM, , NUM, NELEM

! ! --- Step 2: Loop over all selected contact elements ---
! *DO, i, 1, nelem
!     elem_id = elist(i)
