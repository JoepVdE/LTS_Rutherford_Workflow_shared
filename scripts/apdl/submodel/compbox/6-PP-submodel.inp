! /POST1
! SET,LAST  ! Use the last load step and substep
! allsel
! eplot

! /input,4-PP-postprocess_new,inp
/POST1                                ! Postprocessing in POST1

allsel



*DO,ii,1,nsteps
    set,ii

    *DO,i,1,n_strands
        /DELETE,strains_out_strand_%i%_set_%ii%_case_%icase%,out
        *cfopen,strains_out_strand_%i%_set_%ii%_case_%icase%,out,,append
        *vwrite,
('   j','         xel','         yel','         ael','          ex','          ey','          ez','         exy')


        CMSEL,s,m_1_%i%
        allsel,belo,area
        ! Define per-strand element tables for total strain components.
        ! (Previous dead-code: an `etable,e_avg,EPTO,eqv,avg` followed
        !  immediately by `etable,eras` -- the e_avg entry was never read,
        !  removed for clarity.)
        etable,eptox,epto,x,avg
        etable,eptoy,epto,y,avg
        etable,eptoz,epto,z,avg
        etable,eptoxy,epto,xy,avg



        *GET,e_low,ELEM,0,NUM,MIN
        *GET,e_high,ELEM,0,NUM,MAX

        ! Walk through the SELECTED elements via NXTH. The loop variable `j`
        ! is intentionally unused -- it just bounds the iteration count to
        ! the element-number range.
        iel = 0
        *DO,j,e_low,e_high
            *get,iel,elem,iel,nxth
            *get,xel,elem,iel,centroid,x
            *get,yel,elem,iel,centroid,y
            *get,ael,elem,iel,area
            *get,ex,elem,iel,etable,eptox
            *get,ey,elem,iel,etable,eptoy
            *get,ez,elem,iel,etable,eptoz
	        *get,exy,elem,iel,etable,eptoxy


        	*vwrite,j,xel,yel,ael,ex,ey,ez,exy
(1F8.0,7ES12.4)


        *ENDDO


    *ENDDO
*cfclos,strains_out_strand_%i%_set_%ii%_case_%icase%,out

*ENDDO























/eof


cmsel,s,nset_top,node                  ! Select top nodes
*VGET,n_top_index, NODE,,NLIST   ! Store selected node numbers into array

cmsel,s,nset_left,node
*VGET,n_left_index, NODE,,NLIST   ! Store selected node numbers into array



! *GET, nb_top_layer, NODE, 0, COUNT    ! Number of selected top nodes



/DELETE,'fd_temp_%usecase%','txt'
*cfopen,'fd_temp_%usecase%','txt',,'append'

*VWRITE,'Set', 'Time (s)', 'UY (mm)', 'FY_total top (N)', 'UX (mm)', 'Fx_total left (N)'
(A6,2X,A12,2X,A12,2X,A16,2X,A16,2X,A16)
*cfclos

variable_temp1 = 0
variable_temp2 = 0
variable_temp3 = 0

*DO,K,1,n_timesteps
    *cfopen,'fd_temp_%usecase%','txt',,'append'
    SET,K
    ! Get time for this set
    *GET, variable_temp1, ACTIVE, 0, SET, TIME

    allsel
    cmsel,s,nset_top,node  
    ! Get UY for first node in n_top_index array
    *GET, variable_temp2, NODE, n_top_index(2), U, Y
                ! Select top nodes
    FSUM
    *GET,variable_temp3,FSUM,0,ITEM,FY


    allsel
    cmsel,s,nset_left,node 
    *GET, variable_temp4, NODE, n_left_index(1), U, X
    FSUM
    *GET, variable_temp5, FSUM, 0, ITEM, FX


    ! ! Sum FY for all top nodes
    ! variable_temp3 = 0
    ! *DO,J,1,nb_top_layer
    !     *GET, fy_j, NODE, n_top_index(J), RF, Y
    !     variable_temp3 = variable_temp3 + fy_j
    ! *ENDDO

    *VWRITE,K,variable_temp1, variable_temp2, variable_temp3, variable_temp4, variable_temp5
    (F5.2,2X,E12.5,2X,E12.5,2X,E16.10,2X,E16.10,2X,E16.10)
    *cfclos
*ENDDO

!*cfclos  ! Close the file


