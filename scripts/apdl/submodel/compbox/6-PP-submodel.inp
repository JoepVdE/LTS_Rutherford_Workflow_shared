	! RFORCE,3,n_top_index(J),F,Y,!FY_j     ! Define FY variable for node J (var #3)
	! VGET,Fy_temp(1),3                   ! Get time-history into Fy_temp array

	! *DO, ist, 1, step_nb
		! Fy_total(ist) = Fy_total(ist) + Fy_temp(J)
	! *ENDDO
