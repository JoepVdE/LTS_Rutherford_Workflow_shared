! Merge coincident KPs at stack-to-stack interfaces (generated by conformalRutherfordMesh)
/input,stack_interface_nummrg,inp

allsel
aclear,all


! DESIZE,6,4,9999 !6 elements per line, 4 2nd order elements per line
s_ae     = 0.5e-4   ! impregnation + insulation element size [m]
s_ae_str = 0.5e-4   ! strand area element size [m]


!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!!!!!!!!!!!!!!strands meshing

!Copper part
allsel
cmsel,none
asel,none

*DO,i_str,1,n_strands
    *DO,i_sta,1,n_stacks
        cmsel,a,i_%i_sta%_%i_str%
        cmsel,a,o_%i_sta%_%i_str%
    *ENDDO
*ENDDO
mat,2
aesize,all,s_ae_str
amesh,all



!Nb3Sn Part
allsel
cmsel,none
asel,none
*DO,i_str,1,n_strands
    *DO,i_sta,1,n_stacks
        cmsel,a,m_%i_sta%_%i_str%
    *ENDDO
*ENDDO
mat,3
aesize,all,s_ae_str
amesh,all


!!!!!!!!!!!!!!!!!!!!!!!!!
!mesh impregnation inside insulation
allsel
cmsel,none
asel,none
! asel,s,,,100,199
*DO,stack_nr,1,n_stacks
    cmsel,a,out_imp_%stack_nr% !all impreg inside of insulation
*ENDDO

mat,1


! aesize,all,sizeofae
! MSHAPE,0,2D !0?Mesh with quadrilateral-shaped elements when Dimension = 2-D mesh| 1 ? Mesh with triangle-shaped elements when Dimension 
aesize,all,s_ae
amesh,all



!!!!!!!!!!!!!!!
!mesh insulation
allsel
cmsel,none
asel,none
*DO,stack_nr,1,n_stacks
    cmsel,a,str_imp_%stack_nr% !insulation around the strands
*ENDDO

mat,4
allsel,belo,area
lesize,all,s_ae
! MSHAPE,0,2D !0?Mesh with quadrilateral-shaped elements when Dimension = 2-D mesh| 1 ? Mesh with triangle-shaped elements when Dimension
lplot

amesh,all


! !mesh impregnation outside insulation
! allsel
! cmsel,none
! asel,none
! *DO,stack_nr,1,n_stacks
!     cmsel,a,str_outer_imp_%stack_nr%!insulation around the strands
! *ENDDO


! allsel
! cmsel,none
! asel,none
! *DO,stack_nr,1,n_stacks
!     cmsel,a,str_outer_imp_%stack_nr%!insulation around the strands
! *ENDDO


allsel
cmsel,none
asel,none
! *DO,stack_nr,1,n_stacks
cmsel,a,str_outer_imp!insulation around the strands
! *ENDDO

!create single area
*IF,one_area_impreg,EQ,1,THEN 
    AADD,all
    cm,outer_imp_all,area
*ENDIF


mat,1
allsel,belo,area
lesize,all,s_ae
! MSHAPE,0,2D !0?Mesh with quadrilateral-shaped elements when Dimension = 2-D mesh| 1 ? Mesh with triangle-shaped elements when Dimension
amesh,all





!GENERATE SIDE SUPPORT mesh
*IF,side_support,EQ,1,THEN

    allsel
    cmsel,none
    asel,none
    cmsel,s,left_side_support
    cmsel,a,right_side_support
    allsel,belo,area
    lesize,all,s_ae
    mat,5
    amesh,all

*ENDIF