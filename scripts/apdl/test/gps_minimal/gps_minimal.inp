! ==========================================================
! gps_minimal.inp -- minimal isolated test for PLANE183 GPS
!   * goal: confirm the canonical command sequence works
!   * 1 mm x 1 mm linear-elastic square, ~100 elements
!   * GPS via GSGDATA (NOT SECTYPE,GENS -- that's preintegrated shell)
!   * GSBDATA defaults => free axial response, no bending
!   * mixed u-P is on by default here -- comment KEYOPT(1,6,1) if it errors
! ==========================================================

FINISH
/CLEAR,START
/UNITS,SI
/TITLE, gps_minimal_test

/PREP7

! ---- Element technology ----
ET, 1, PLANE183
KEYOPT, 1, 3, 5     ! Generalized plane strain
KEYOPT, 1, 6, 1     ! Mixed u-P formulation (compatibility test)

! ---- Material (copper-like, linear elastic for this isolation test) ----
MP, EX,   1, 130E9
MP, PRXY, 1, 0.34

! ---- Geometry: 1 mm x 1 mm square ----
side = 1.0E-3
RECTNG, 0, side, 0, side

! ---- GPS reference geometry: MUST be set before mesh ----
! GSGDATA, LFIBER, XREF, YREF, ROTX0, ROTY0
!   LFIBER -- fiber length (z extent)         default 1 m
!   XREF,YREF -- in-plane reference point     COORDINATES, not node IDs
!   ROTX0,ROTY0 -- initial fiber rotations    default 0
GSGDATA, 1.0, side/2, side/2, 0, 0

! ---- Mesh ----
AESIZE, ALL, side/10
AMESH, ALL

! ---- Print mesh stats (so we can see in the log if amesh worked) ----
ALLSEL
*GET, n_elem, ELEM, 0, COUNT
*GET, n_node, NODE, 0, COUNT
/COM, ===========================================================
/COM, MESH_RESULT: n_elements = %n_elem%   n_nodes = %n_node%
/COM, ===========================================================

! ---- Boundary conditions ----
SELTOL, 1.E-7

! bottom edge: UY = 0
NSEL, S, LOC, Y, 0
D, ALL, UY, 0

! bottom-left node: anchor UX
NSEL, S, LOC, Y, 0
NSEL, R, LOC, X, 0
D, ALL, UX, 0

! top edge: small compressive UY (5% strain)
ALLSEL
NSEL, S, LOC, Y, side
D, ALL, UY, -0.05*side
ALLSEL

! GPS load/BC: defaults = F=0, MX=0, MY=0
!   -> zero net axial force, no bending moments
!   -> fiber is free to Poisson-contract in z (this is what we want for compaction)
GSBDATA

! ---- Solve ----
/SOLU
ANTYPE, STATIC
NLGEOM, ON
NEQIT, 25
NSUBST, 5, 20, 2
OUTRES, ALL, ALL
SOLVE
FINISH

! ---- Post: report GPS results ----
/POST1
SET, LAST
/COM, ===========================================================
/COM, GPS_RESULTS (fiber length change, rotations, reactions):
GSLIST, RESULTS
GSLIST, REACTIONS
/COM, ===========================================================

FINISH
/EXIT
